OLLAMA_PORT=11434
OPENWEBUI_PORT=3000
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT_SECONDS=60
OLLAMA_RETRIES=3
MAX_TOOL_STEPS=5
MAX_HISTORY=12
LOG_LEVEL=INFO
SAFE_WORKSPACE_ROOT=/app
ALLOWED_SHELL_PREFIXES=ls,dir,pwd,echo,cat,type,python -c
TOOL_RATE_LIMIT_COUNT=60
TOOL_RATE_LIMIT_WINDOW_SECONDS=60
TOOL_AUDIT_LOG_PATH=logs/tool_audit.log
DANGEROUS_ACTIONS_REQUIRE_CONFIRMATION=true
DANGEROUS_CONFIRMATION_TOKEN=CONFIRM

# Optional: only set if needed by your workflows.
HF_TOKEN=
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com
GITHUB_MONITOR_REPOS=
GITHUB_ALERT_CHANNEL=
GITHUB_ALERT_POLL_SECONDS=120
GITHUB_DIGEST_REPOS=
GITHUB_DIGEST_CHANNEL=
GITHUB_DIGEST_HOUR=9
GITHUB_DIGEST_MINUTE=0
GITHUB_TZ_OFFSET_MINUTES=330
JENKINS_URL=
JENKINS_USER=
JENKINS_API_TOKEN=
AZDO_ORG_URL=
AZDO_PAT=
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_ALLOWED_CHANNEL=
SLACK_REQUIRE_MENTION=true
MAX_SLACK_REPLY_CHARS=38000
